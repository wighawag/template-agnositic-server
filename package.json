{
  "name": "template-agnostic-server-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "ldenv": "^0.3.16",
    "zellij-launcher": "^0.0.1"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "---------------------- FORMAT ----------------------": "",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "---------------------- DEV ----------------------": "",
    "cf-worker:dev": "pnpm --filter template-agnostic-server-cf-worker dev",
    "server:dev": "pnpm --filter template-agnostic-server-app dev",
    "---------------------- DEPLOY ----------------------": "",
    "build": "ldenv pnpm run -r build",
    "deploy:cf": "pnpm run --filter template-agnostic-server-server-cf-worker deploy",
    "---------------------- RUN FULL LOCAL SETUP ----------------------": "",
    "stop": "zellij kill-session $npm_package_name",
    "start": "zellij-launcher --layout zellij.kdl a $npm_package_name || zellij --layout zellij.kdl -s $npm_package_name"
  }
}
